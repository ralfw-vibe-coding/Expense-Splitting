{
  "tasks": {
    "dev": "deno run --env-file=.env --allow-net --allow-env --allow-read main.ts",
    "test": "deno test --allow-read --allow-write --allow-env",
    "check": "deno check main.ts",
    "fmt": "deno fmt"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  }
}
